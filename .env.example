TELEGRAM_BOT_TOKEN=PASTE_TOKEN_HERE
# Куда постить: ID чата/канала/группы. Для канала обычно вида -1001234567890
TELEGRAM_CHAT_ID=

# Источник постов: локальный Excel путь ИЛИ Google Sheets URL.
POSTS_XLSX_PATH=posts.xlsx
POSTS_SHEET_NAME=posts

# Для Google Sheets (один из двух вариантов):
# 1) путь к json-файлу service account
GOOGLE_SERVICE_ACCOUNT_JSON=
# 2) или весь json ОДНОЙ СТРОКОЙ (предпочтительно, если не хотите файл)
# GOOGLE_SERVICE_ACCOUNT_JSON_INLINE={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","token_uri":"https://oauth2.googleapis.com/token"}
GOOGLE_SERVICE_ACCOUNT_JSON_INLINE=

# Раз в сколько дней публиковать (по задаче: 2)
INTERVAL_DAYS=2

# Если true — отправит первый пост сразу после запуска, затем по расписанию
START_IMMEDIATELY=true

# Если true — скрипт сделает 0/1 публикацию и завершится (удобно для Планировщика задач Windows)
RUN_ONCE=false

# Файл состояния (индекс текущего поста + время последней публикации)
STATE_PATH=state.json

# Уровень логов в консоль: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
